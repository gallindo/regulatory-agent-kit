# ---------------------------------------------------------------
# regulatory-agent-kit — Environment Variables
# ---------------------------------------------------------------
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: .env is in .gitignore — never commit secrets.
# Full reference: docs/local-development.md#2-configuration-reference
# ---------------------------------------------------------------

# --- LLM Provider API Keys (at least one is required) ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AWS_ACCESS_KEY_ID=        # For Bedrock
# AWS_SECRET_ACCESS_KEY=    # For Bedrock
# AWS_DEFAULT_REGION=       # For Bedrock

# --- Git Provider Tokens (for private repositories) ---
# GITHUB_TOKEN=
# GITLAB_TOKEN=

# --- Database (full mode only) ---
DATABASE_URL=postgresql://rak:rak_dev_password@localhost:5432/rak

# --- Elasticsearch (full mode only) ---
ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_PASSWORD=rak_dev_password

# --- MLflow (full mode only) ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Temporal (full mode only) ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# --- Kafka (optional — for event streaming) ---
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- LiteLLM Proxy (full mode only) ---
LITELLM_MASTER_KEY=sk-rak-dev-key

# --- Application Settings ---
RAK_CACHE_TTL_DAYS=7
RAK_LOG_LEVEL=INFO
RAK_LOG_FORMAT=json

# --- Docker Compose Defaults ---
POSTGRES_USER=rak
POSTGRES_PASSWORD=rak_dev_password
POSTGRES_DB=rak
