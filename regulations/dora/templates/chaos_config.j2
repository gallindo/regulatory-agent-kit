{# Generated by regulatory-agent-kit — {{ rule_id }} #}
{# DORA Article 25 — Chaos engineering configuration #}
testing:
  chaos_engineering:
    enabled: true
    framework: "{{ chaos_framework | default('litmus') }}"
    experiments:
      - name: "pod-failure"
        target: "{{ service_name | default('service') }}"
        schedule: "{{ chaos_schedule | default('weekly') }}"
      - name: "network-latency"
        target: "{{ service_name | default('service') }}"
        latency_ms: {{ latency_ms | default(500) }}
      - name: "resource-exhaustion"
        target: "{{ service_name | default('service') }}"
        cpu_percent: {{ cpu_percent | default(80) }}
    safety:
      abort_on_failure: true
      max_duration_minutes: {{ max_duration | default(30) }}
