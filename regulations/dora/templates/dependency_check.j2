{# Generated by regulatory-agent-kit — {{ rule_id }} #}
{# DORA Article 9(3) — Dependency vulnerability scanning #}
{% if build_tool == "maven" %}
<plugin>
    <groupId>org.owasp</groupId>
    <artifactId>dependency-check-maven</artifactId>
    <version>{{ dependency_check_version | default('9.0.0') }}</version>
    <configuration>
        <failBuildOnCVSS>{{ cvss_threshold | default(7) }}</failBuildOnCVSS>
    </configuration>
</plugin>
{% elif build_tool == "gradle" %}
plugins {
    id 'org.owasp.dependencycheck' version '{{ dependency_check_version | default("9.0.0") }}'
}
dependencyCheck {
    failBuildOnCVSS = {{ cvss_threshold | default(7) }}
}
{% elif build_tool == "pip" %}
# Add to CI pipeline or pre-commit:
# pip-audit --strict --desc on
# safety check --full-report
{% endif %}
