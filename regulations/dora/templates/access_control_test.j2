{# Test template for DORA-ICT-005 — Access control annotation #}
{% if language == "java" %}
@Test
void {{ class_name | snake_case }}_shouldRequireAuthentication() {
    RolesAllowed annotation = {{ class_name }}.class.getAnnotation(RolesAllowed.class);
    assertNotNull(annotation, "{{ class_name }} must have @RolesAllowed per DORA Article 9(4)(b)");
    assertTrue(annotation.value().length > 0, "At least one role must be specified");
}
{% elif language == "python" %}
def test_{{ class_name | snake_case }}_requires_authentication():
    """{{ class_name }} must have permission_classes per DORA Article 9(4)(b)."""
    view = {{ class_name }}()
    assert hasattr(view, "permission_classes"), (
        "{{ class_name }} must define permission_classes"
    )
{% endif %}
