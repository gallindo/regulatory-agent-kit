{# Test template for DORA-ICT-001 — Audit logging annotation #}
{# Validates that the @AuditLog annotation is present and configured correctly #}
{% if language == "java" %}
@Test
void {{ class_name | snake_case }}_shouldHaveAuditLogAnnotation() {
    AuditLog annotation = {{ class_name }}.class.getAnnotation(AuditLog.class);
    assertNotNull(annotation, "{{ class_name }} must have @AuditLog per DORA Article 12");
    assertEquals("{{ audit_level | default('INFO') }}", annotation.level());
    assertTrue(annotation.retentionDays() >= 365, "Retention must be >= 365 days");
}
{% elif language == "python" %}
def test_{{ class_name | snake_case }}_has_audit_log():
    """{{ class_name }} must have @audit_log per DORA Article 12."""
    assert hasattr({{ class_name }}, "_audit_log_config"), (
        "{{ class_name }} must be decorated with @audit_log"
    )
    config = {{ class_name }}._audit_log_config
    assert config["retention_days"] >= 365
{% endif %}
