      - name: "{{ alt_provider | default('') }}"
        evaluation_status: "{{ evaluation_status | default('pending') }}"
    data_portability:
      format: "{{ data_format | default('') }}"
      extraction_tested: {{ extraction_tested | default('false') }}
    business_continuity:
      interim_solution: "{{ interim_solution | default('') }}"
      max_acceptable_downtime: "{{ max_downtime | default('4h') }}"
    last_reviewed: "{{ review_date | default('') }}"
