{# DORA Article 19(4)(a) — Initial notification within 4 hours #}
{% if language == "java" %}
/**
 * DORA Article 19(4)(a): Initial notification within 4 hours of major classification.
 * DORA Article 19(4)(b): Intermediate report within 72 hours.
 * DORA Article 19(4)(c): Final report within 1 month.
 */
public void sendInitialNotification(Incident incident) {
    Instant deadline = incident.getClassifiedAt().plus(Duration.ofHours(4));
    if (Instant.now().isAfter(deadline)) {
        log.error("DORA BREACH: Initial notification deadline exceeded for {}", incident.getId());
    }
    notificationService.send(buildInitialReport(incident));
    auditLog.record("initial_notification_sent", incident.getId(), Instant.now());
}
