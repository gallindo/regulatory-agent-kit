def send_initial_notification(self, incident: Incident) -> None:
    """DORA Art. 19(4)(a): Initial notification within 4h of classification."""
    deadline = incident.classified_at + timedelta(hours=4)
    if datetime.now(UTC) > deadline:
        logger.error("DORA BREACH: Initial notification deadline exceeded for %s", incident.id)
    self.notification_service.send(self._build_initial_report(incident))
