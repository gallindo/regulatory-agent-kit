{# Test template for DORA-IR-001 — Incident classification #}
{% if language == "java" %}
@Test
void shouldClassifyCriticalIncident() {
    IncidentSeverity result = classifier.classifyBySeverity(100, 1000, Duration.ofHours(3), false, 1);
    assertEquals(IncidentSeverity.CRITICAL, result, "10% clients + 3h duration = CRITICAL");
}

@Test
void shouldClassifyMajorIncident() {
    IncidentSeverity result = classifier.classifyBySeverity(60, 1000, Duration.ofMinutes(90), false, 1);
    assertEquals(IncidentSeverity.MAJOR, result, "6% clients + 90min = MAJOR");
}
{% elif language == "python" %}
def test_classify_critical_incident():
    result = classifier.classify_by_severity(100, 1000, 180, False, 1)
    assert result == IncidentSeverity.CRITICAL

def test_classify_major_incident():
    result = classifier.classify_by_severity(60, 1000, 90, False, 1)
    assert result == IncidentSeverity.MAJOR
{% endif %}
