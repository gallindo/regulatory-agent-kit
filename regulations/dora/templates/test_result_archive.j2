{# Generated by regulatory-agent-kit — {{ rule_id }} #}
{# DORA Article 24(5) — Test result archival #}
{% if language == "java" %}
public void archiveResults(TestReport report) {
    ArchiveEntry entry = ArchiveEntry.builder()
        .reportId(report.getId())
        .testType(report.getType())
        .executedAt(report.getExecutedAt())
        .result(report.getResult())
        .retentionYears({{ retention_years | default(5) }})
        .build();
    archiveService.store(entry);
    auditLog.record("test_results_archived", report.getId());
}
{% elif language == "python" %}
def archive_results(self, report: TestReport) -> None:
    """DORA Art. 24(5): Archive test results for regulatory reporting."""
    entry = ArchiveEntry(
        report_id=report.id,
        test_type=report.type,
        executed_at=report.executed_at,
        result=report.result,
        retention_years={{ retention_years | default(5) }},
    )
    self.archive_service.store(entry)
    self.audit_log.record("test_results_archived", report.id)
{% endif %}
