{# DORA Article 18, RTS JC 2023 83 — Incident classification #}
{% if language == "java" %}
public enum IncidentSeverity {
    CRITICAL,   // >= 10% clients affected, data loss, >= 2h duration
    MAJOR,      // >= 5% clients, service degradation, >= 1h
    SIGNIFICANT,// >= 1% clients, partial impact
    MINOR       // < 1% clients, no data loss, < 30min
}

public IncidentSeverity classifyBySeverity(
    int clientsAffected,
    int totalClients,
    Duration duration,
    boolean dataLoss,
    int geographicSpread
) {
    double clientRatio = (double) clientsAffected / totalClients;
    if (clientRatio >= 0.10 || dataLoss || duration.toHours() >= 2) {
        return IncidentSeverity.CRITICAL;
    }
    if (clientRatio >= 0.05 || duration.toHours() >= 1) {
        return IncidentSeverity.MAJOR;
    }
    if (clientRatio >= 0.01) {
        return IncidentSeverity.SIGNIFICANT;
    }
    return IncidentSeverity.MINOR;
}
{% elif language == "python" %}
class IncidentSeverity(str, Enum):
    CRITICAL = "critical"      # >= 10% clients, data loss, >= 2h
    MAJOR = "major"            # >= 5% clients, degradation, >= 1h
    SIGNIFICANT = "significant"# >= 1% clients, partial impact
    MINOR = "minor"            # < 1% clients, no data loss, < 30min

def classify_by_severity(
    self,
    clients_affected: int,
    total_clients: int,
    duration_minutes: int,
    data_loss: bool,
    geographic_spread: int,
) -> IncidentSeverity:
    ratio = clients_affected / max(total_clients, 1)
    if ratio >= 0.10 or data_loss or duration_minutes >= 120:
        return IncidentSeverity.CRITICAL
    if ratio >= 0.05 or duration_minutes >= 60:
        return IncidentSeverity.MAJOR
    if ratio >= 0.01:
        return IncidentSeverity.SIGNIFICANT
    return IncidentSeverity.MINOR
