{# DORA Article 28(3) — Third-party dependency audit register #}
# ICT Third-Party Dependency Audit Register
# Generated per DORA Article 28(3) and ITS on registers of information

dependencies:
{% for dep in dependencies | default([]) %}
  - name: "{{ dep.name }}"
    version: "{{ dep.version }}"
    provider: "{{ dep.provider | default('unknown') }}"
    classification: "{{ dep.classification | default('standard') }}"
    criticality: "{{ dep.criticality | default('low') }}"
    license: "{{ dep.license | default('unknown') }}"
    last_audit: "{{ dep.last_audit | default('') }}"
{% endfor %}

audit:
  last_conducted: "{{ audit_date | default('') }}"
  next_scheduled: "{{ next_audit_date | default('') }}"
  auditor: "{{ auditor | default('') }}"
