{# DORA Article 19(4)(b) — Intermediate report within 72 hours #}
{% if language == "java" %}
public void sendIntermediateReport(Incident incident) {
    Instant deadline = incident.getClassifiedAt().plus(Duration.ofHours(72));
    IntermediateReport report = IntermediateReport.builder()
        .incidentId(incident.getId())
        .rootCauseProgress(incident.getRootCauseAnalysisStatus())
        .clientsAffected(incident.getClientsAffected())
        .mitigationActions(incident.getMitigationActions())
        .deadline(deadline)
        .build();
    reportingService.submit(report);
}
{% elif language == "python" %}
def send_intermediate_report(self, incident: Incident) -> None:
    """DORA Art. 19(4)(b): Intermediate report within 72h."""
    deadline = incident.classified_at + timedelta(hours=72)
    report = IntermediateReport(
        incident_id=incident.id,
        root_cause_progress=incident.root_cause_analysis_status,
        clients_affected=incident.clients_affected,
        mitigation_actions=incident.mitigation_actions,
        deadline=deadline,
    )
    self.reporting_service.submit(report)
{% endif %}
