{# Generated by regulatory-agent-kit — {{ rule_id }} #}
{# DORA Article 9(4)(c) — Encryption at rest and in transit #}
security:
  encryption:
    at_rest:
      enabled: true
      algorithm: "{{ encryption_algorithm | default('AES-256-GCM') }}"
      key_management: "{{ key_management | default('external') }}"
    in_transit:
      enabled: true
      protocol: "{{ tls_protocol | default('TLS 1.3') }}"
      min_version: "{{ tls_min_version | default('1.2') }}"
      certificate_rotation_days: {{ cert_rotation_days | default(90) }}
