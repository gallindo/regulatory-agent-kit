{# Generated by regulatory-agent-kit — {{ rule_id }} #}
{# DORA Article 30 — Key contractual provisions #}
third_party:
  contract:
    audit_rights:
      enabled: true
      frequency: "{{ audit_frequency | default('annual') }}"
      scope: "{{ audit_scope | default('full') }}"
    data_location:
      primary: "{{ data_location | default('EU') }}"
      allowed_jurisdictions: {{ allowed_jurisdictions | default('["EU"]') }}
      transfer_restrictions: true
    security_requirements:
      encryption_required: true
      incident_notification_hours: {{ notification_hours | default(4) }}
      penetration_testing: true
    termination:
      notice_period_days: {{ notice_period | default(90) }}
      data_return_days: {{ data_return_days | default(30) }}
      data_deletion_confirmed: false
