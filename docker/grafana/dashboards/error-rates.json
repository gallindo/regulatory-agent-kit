{
  "uid": "rak-error-rates",
  "title": "Error Rates",
  "description": "Regulatory Agent Kit — pipeline failures, tool errors, and error breakdowns by agent",
  "tags": ["rak", "errors"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "title": "Pipeline Failure Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rak_pipeline_runs_failed) / clamp_min(sum(rak_pipeline_runs_total), 1)",
          "legendFormat": "Failure Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.15 }
            ]
          }
        }
      }
    },
    {
      "title": "Failed Tool Invocations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(rak_tool_invocations_total{success=\"False\"}[5m])",
          "legendFormat": "{{ tool }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "title": "Error Rate by Agent",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (agent) (rak_tool_invocations_total{success=\"False\"})",
          "legendFormat": "{{ agent }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Pipeline Failures Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(rak_pipeline_runs_failed[5m])",
          "legendFormat": "{{ regulation_id }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    }
  ]
}
