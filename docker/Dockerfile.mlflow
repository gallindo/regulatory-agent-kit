# ---------------------------------------------------------------
# regulatory-agent-kit — MLflow Server
# ---------------------------------------------------------------
# Runs the MLflow tracking server for LLM observability.
#
# Build:  docker build -f docker/Dockerfile.mlflow -t rak:mlflow .
# ---------------------------------------------------------------

FROM python:3.12-slim

LABEL org.opencontainers.image.description="regulatory-agent-kit MLflow server"

RUN pip install --no-cache-dir \
    "mlflow[postgres]>=2.18.0" \
    psycopg2-binary \
    boto3

RUN groupadd --gid 1000 mlflow && \
    useradd --uid 1000 --gid mlflow --create-home mlflow

# Create artifact directory owned by mlflow user
RUN mkdir -p /mlflow-artifacts && chown mlflow:mlflow /mlflow-artifacts

USER mlflow

EXPOSE 5000

ENTRYPOINT ["mlflow", "server"]
CMD [ \
    "--host", "0.0.0.0", \
    "--port", "5000", \
    "--default-artifact-root", "/mlflow-artifacts" \
]
# Backend store URI is set via MLFLOW_BACKEND_STORE_URI env var in docker-compose.yml
